# ProjectCal local/cloud configuration.
# Copy to .env for Docker, or set these values as Windows environment variables / user-secrets.

# OpenAI speech-to-text. Required for real transcription.
OPENAI_API_KEY=sk-your-openai-api-key
OpenAI__TranscriptionModel=gpt-4o-mini-transcribe

# Supabase Postgres. Use either format:
# 1) .NET/Npgsql format from Supabase database settings:
SUPABASE_DB_CONNECTION_STRING=Host=aws-0-eu-central-1.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.your-project-ref;Password=your-password;SSL Mode=Require

# 2) URL format, if Supabase gives you postgresql://...
# DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

# API auth. Use a long random value in production.
Jwt__SigningKey=replace-with-a-long-random-signing-key-at-least-32-bytes
