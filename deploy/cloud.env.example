# Copy these values into your cloud hosting environment.
# Do not rename this file to .env with real secrets and commit it.

Database__Provider=Postgres
SUPABASE_DB_CONNECTION_STRING=Host=aws-0-region.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.project-ref;Password=replace-me;SSL Mode=Require

ASPNETCORE_URLS=http://0.0.0.0:10000
Jwt__Issuer=ProjectCal
Jwt__Audience=ProjectCal.Client
Jwt__SigningKey=replace-with-a-long-random-secret-at-least-32-bytes

Storage__RootPath=/app/App_Data/media

# Enables Groq transcription in ProjectCal.Api.
GROQ_API_KEY=
Groq__TranscriptionModel=whisper-large-v3-turbo
