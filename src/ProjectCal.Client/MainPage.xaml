<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ProjectCal_Client.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="#EEF8F7"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#EEF8F7" />
        <SolidColorBrush x:Key="PanelBrush" Color="#F7FCFB" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="LineBrush" Color="#D6ECEA" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#607370" />
        <SolidColorBrush x:Key="InkBrush" Color="#183331" />
        <SolidColorBrush x:Key="InputBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="InputHoverBrush" Color="#F2FBFA" />
        <SolidColorBrush x:Key="InputPressedBrush" Color="#E6F7F5" />
        <SolidColorBrush x:Key="InputTextBrush" Color="#183331" />
        <SolidColorBrush x:Key="InputPlaceholderBrush" Color="#6D8582" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#D8F4F1" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0E9F9A" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B24A43" />

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InputTextBrush}" />
            <Setter Property="PlaceholderForeground" Value="{StaticResource InputPlaceholderBrush}" />
            <Setter Property="BorderBrush" Value="#12413F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="12,0,12,0" />
            <Setter Property="SelectionHighlightColor" Value="#0E9F9A" />
        </Style>

        <Style TargetType="RichEditBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InputTextBrush}" />
            <Setter Property="BorderBrush" Value="#12413F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="12,10,12,10" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InputTextBrush}" />
            <Setter Property="BorderBrush" Value="#12413F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="12,0,12,0" />
            <Setter Property="SelectionHighlightColor" Value="#0E9F9A" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InputTextBrush}" />
            <Setter Property="BorderBrush" Value="#12413F" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="40" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InputTextBrush}" />
            <Setter Property="BorderBrush" Value="#12413F" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="40" />
        </Style>

        <Style TargetType="TimePicker">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InputTextBrush}" />
            <Setter Property="BorderBrush" Value="#12413F" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="40" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="14,8,14,8" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid
            x:Name="AuthScreen"
            Padding="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="480" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="1"
                Grid.Column="1"
                Padding="30"
                Background="{StaticResource PanelAltBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="10">
                        <Border
                            Width="44"
                            Height="44"
                            HorizontalAlignment="Left"
                            Background="{StaticResource AccentSoftBrush}"
                            CornerRadius="8">
                            <FontIcon
                                FontSize="22"
                                Foreground="{StaticResource AccentBrush}"
                                Glyph="&#xE787;" />
                        </Border>
                        <TextBlock
                            Foreground="{StaticResource InkBrush}"
                            FontSize="32"
                            FontWeight="SemiBold"
                            Text="DayScribe" />
                        <TextBlock
                            x:Name="AuthSubtitleText"
                            Foreground="{StaticResource MutedTextBrush}"
                            FontSize="14"
                            LineHeight="20"
                            Text="Sign in to open your notes, calendar and voice transcripts."
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Spacing="12">
                        <StackPanel Spacing="6">
                            <TextBlock
                                x:Name="EmailLabel"
                                Foreground="{StaticResource InkBrush}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="Email" />
                            <TextBox
                                x:Name="EmailBox"
                                PlaceholderText="you@example.com" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock
                                x:Name="PasswordLabel"
                                Foreground="{StaticResource InkBrush}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="Password" />
                            <PasswordBox
                                x:Name="PasswordBox"
                                PlaceholderText="Minimum 8 characters" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock
                                x:Name="ResetTokenLabel"
                                Foreground="{StaticResource InkBrush}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="Reset token" />
                            <TextBox
                                x:Name="TokenBox"
                                PlaceholderText="Only needed after Forgot" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Spacing="10">
                        <Button
                            HorizontalAlignment="Stretch"
                            Background="{StaticResource AccentBrush}"
                            Click="Login_Click"
                            Foreground="White">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Contact" />
                                <TextBlock x:Name="LoginButtonText" Text="Login" />
                            </StackPanel>
                        </Button>
                        <Button
                            HorizontalAlignment="Stretch"
                            Background="{StaticResource AccentSoftBrush}"
                            Click="Register_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="AddFriend" />
                                <TextBlock x:Name="RegisterButtonText" Text="Register" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Grid Grid.Row="3" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button
                            HorizontalAlignment="Stretch"
                            Click="ForgotPassword_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Help" />
                                <TextBlock x:Name="ForgotButtonText" Text="Forgot" />
                            </StackPanel>
                        </Button>
                        <Button
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Click="ResetPassword_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Repair" />
                                <TextBlock x:Name="ResetButtonText" Text="Reset" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border
                        Grid.Row="4"
                        Padding="12"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                FontSize="16"
                                Foreground="{StaticResource AccentBrush}"
                                Glyph="&#xE946;" />
                            <TextBlock
                                x:Name="AuthStatusBox"
                                Grid.Column="1"
                                Foreground="{StaticResource MutedTextBrush}"
                                LineHeight="18"
                                Text="Register once, then login. Use Forgot and Reset only if you need to change the password."
                                TextWrapping="Wrap" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid
            x:Name="AppShell"
            Padding="18"
            ColumnSpacing="14"
            Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="430" />
            </Grid.ColumnDefinitions>

            <Border
                Padding="18"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            Foreground="{StaticResource InkBrush}"
                            FontSize="26"
                            FontWeight="SemiBold"
                            Text="DayScribe" />
                        <TextBlock
                            x:Name="UserLabel"
                            Foreground="{StaticResource MutedTextBrush}"
                            FontSize="13"
                            Text="Calendar-first notes and voice" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Spacing="10">
                        <Button
                            HorizontalAlignment="Stretch"
                            Background="{StaticResource AccentBrush}"
                            Click="Sync_Click"
                            Foreground="White">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Sync" />
                                <TextBlock x:Name="SyncButtonText" Text="Sync" />
                            </StackPanel>
                        </Button>
                        <Button
                            HorizontalAlignment="Stretch"
                            Click="Settings_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Setting" />
                                <TextBlock x:Name="SettingsButtonText" Text="Settings" />
                            </StackPanel>
                        </Button>
                        <Button
                            HorizontalAlignment="Stretch"
                            Click="Logout_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Back" />
                                <TextBlock x:Name="LogoutButtonText" Text="Logout" />
                            </StackPanel>
                        </Button>
                        <Border
                            Padding="12"
                            Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="10">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Width="34"
                                        Height="34"
                                        Background="{StaticResource AccentSoftBrush}"
                                        CornerRadius="8">
                                        <FontIcon
                                            x:Name="StatusGlyph"
                                            FontSize="17"
                                            Foreground="{StaticResource AccentBrush}"
                                            Glyph="&#xE930;" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock
                                            x:Name="ActivityTitleText"
                                            Foreground="{StaticResource InkBrush}"
                                            FontWeight="SemiBold"
                                            Text="Activity" />
                                        <TextBlock
                                            x:Name="StatusBox"
                                            Foreground="{StaticResource MutedTextBrush}"
                                            LineHeight="18"
                                            MaxLines="3"
                                            Text="Ready"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border
                                        Padding="9"
                                        Background="{StaticResource PanelBrush}"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="3">
                                            <FontIcon
                                                FontSize="14"
                                                Foreground="{StaticResource AccentBrush}"
                                                Glyph="&#xE895;" />
                                            <TextBlock
                                                x:Name="SyncMetricTitleText"
                                                Foreground="{StaticResource InkBrush}"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                MaxLines="2"
                                                Text="Sync"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="WrapWholeWords" />
                                            <TextBlock
                                                x:Name="SyncStateText"
                                                Foreground="{StaticResource MutedTextBrush}"
                                                FontSize="11"
                                                MaxLines="2"
                                                Text="Idle"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Grid.Column="1"
                                        Padding="9"
                                        Background="{StaticResource PanelBrush}"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="3">
                                            <FontIcon
                                                FontSize="14"
                                                Foreground="{StaticResource AccentBrush}"
                                                Glyph="&#xE8B9;" />
                                            <TextBlock
                                                x:Name="MediaMetricTitleText"
                                                Foreground="{StaticResource InkBrush}"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                MaxLines="2"
                                                Text="Media"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="WrapWholeWords" />
                                            <TextBlock
                                                x:Name="MediaStateText"
                                                Foreground="{StaticResource MutedTextBrush}"
                                                FontSize="11"
                                                MaxLines="2"
                                                Text="None"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Padding="9"
                                        Background="{StaticResource PanelBrush}"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon
                                                FontSize="14"
                                                Foreground="{StaticResource AccentBrush}"
                                                Glyph="&#xE8D2;" />
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock
                                                    x:Name="TranscriptMetricTitleText"
                                                    Foreground="{StaticResource InkBrush}"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    MaxLines="2"
                                                    Text="Transcript"
                                                    TextTrimming="CharacterEllipsis"
                                                    TextWrapping="WrapWholeWords" />
                                                <TextBlock
                                                    x:Name="TranscriptStateText"
                                                    Foreground="{StaticResource MutedTextBrush}"
                                                    FontSize="11"
                                                    MaxLines="2"
                                                    Text="No audio"
                                                    TextTrimming="CharacterEllipsis"
                                                    TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Padding="16"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="2">
                            <TextBlock
                                x:Name="TimelineTitleText"
                                Foreground="{StaticResource InkBrush}"
                                FontSize="22"
                                FontWeight="SemiBold"
                                Text="Day timeline" />
                            <TextBlock
                                x:Name="TimelineSubtitleText"
                                Foreground="{StaticResource MutedTextBrush}"
                                FontSize="13"
                                Text="Focus on one day, one hour at a time" />
                        </StackPanel>

                        <StackPanel
                            Grid.Column="1"
                            Spacing="4">
                            <TextBlock
                                x:Name="DayPickerHeaderText"
                                Foreground="{StaticResource InkBrush}"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Text="Day" />
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="64" />
                                    <ColumnDefinition Width="82" />
                                </Grid.ColumnDefinitions>
                                <ComboBox
                                    x:Name="MonthBox"
                                    HorizontalAlignment="Stretch"
                                    SelectionChanged="DateSelector_SelectionChanged" />
                                <ComboBox
                                    x:Name="DayBox"
                                    Grid.Column="1"
                                    HorizontalAlignment="Stretch"
                                    SelectionChanged="DateSelector_SelectionChanged" />
                                <ComboBox
                                    x:Name="YearBox"
                                    Grid.Column="2"
                                    HorizontalAlignment="Stretch"
                                    SelectionChanged="DateSelector_SelectionChanged" />
                            </Grid>
                        </StackPanel>
                        <TextBox
                            x:Name="SearchBox"
                            Grid.Column="2"
                            Header="Search"
                            PlaceholderText="Search notes or transcript"
                            TextChanged="SearchBox_TextChanged" />
                    </Grid>
                </Border>

                <Border
                    Grid.Row="1"
                    Padding="12"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <ScrollViewer>
                        <StackPanel x:Name="HoursPanel" Spacing="6" />
                    </ScrollViewer>
                </Border>
            </Grid>

            <Border
                Grid.Column="2"
                Padding="16"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            x:Name="AllNotesTitleText"
                            Foreground="{StaticResource InkBrush}"
                            FontSize="21"
                            FontWeight="SemiBold"
                            Text="All notes" />
                        <TextBlock
                            x:Name="AllNotesSubtitleText"
                            Foreground="{StaticResource MutedTextBrush}"
                            FontSize="12"
                            Text="Open any note as a full canvas"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1">
                        <StackPanel
                            x:Name="AllNotesPanel"
                            Spacing="6" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border
                Grid.Column="3"
                Padding="18"
                Background="{StaticResource PanelAltBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            x:Name="NotePanelTitleText"
                            Foreground="{StaticResource InkBrush}"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Text="Note" />
                        <TextBlock
                            x:Name="NotePanelSubtitleText"
                            Foreground="{StaticResource MutedTextBrush}"
                            FontSize="13"
                            Text="Write, attach photos, or record audio" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1">
                        <StackPanel Spacing="14">
                            <Grid ColumnSpacing="10" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TimePicker
                                    x:Name="StartTimePicker"
                                    ClockIdentifier="24HourClock"
                                    Header="Start" />
                                <TimePicker
                                    x:Name="EndTimePicker"
                                    Grid.Column="1"
                                    ClockIdentifier="24HourClock"
                                    Header="End" />
                            </Grid>

                            <Border
                                Padding="14"
                                Background="{StaticResource AccentSoftBrush}"
                                BorderBrush="#A8E3DF"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock
                                                x:Name="VoiceMediaTitleText"
                                                Foreground="{StaticResource InkBrush}"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Text="Voice &amp; media" />
                                            <TextBlock
                                                x:Name="VoiceMediaSubtitleText"
                                                Foreground="{StaticResource MutedTextBrush}"
                                                FontSize="12"
                                                MaxLines="2"
                                                Text="Record audio or attach photos."
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                        <TextBlock
                                            x:Name="TranscriptionLanguageSummaryText"
                                            Foreground="{StaticResource MutedTextBrush}"
                                            FontSize="12"
                                            MaxLines="2"
                                            Text="Transcript language is set in Settings"
                                            TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <Button
                                            x:Name="RecordButton"
                                            HorizontalAlignment="Stretch"
                                            Background="{StaticResource AccentBrush}"
                                            Click="RecordAudio_Click"
                                            Foreground="White">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <SymbolIcon Symbol="Microphone" />
                                                <TextBlock
                                                    x:Name="RecordButtonText"
                                                    Text="Record audio"
                                                    TextWrapping="NoWrap" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            HorizontalAlignment="Stretch"
                                            Click="AttachPhoto_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <SymbolIcon Symbol="Pictures" />
                                                <TextBlock
                                                    x:Name="AddPhotoButtonText"
                                                    Text="Add photo"
                                                    TextWrapping="NoWrap" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <Border
                                        x:Name="MediaActionBorder"
                                        Padding="10"
                                        Background="{StaticResource PanelAltBrush}"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Visibility="Collapsed">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ProgressRing
                                                x:Name="MediaActionRing"
                                                Width="20"
                                                Height="20"
                                                IsActive="False" />
                                                <TextBlock
                                                    x:Name="MediaActionText"
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource MutedTextBrush}"
                                                    MaxLines="3"
                                                    Text="Media is ready"
                                                    TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>

                                    <Border
                                        Padding="10"
                                        Background="{StaticResource PanelAltBrush}"
                                        BorderBrush="#A8E3DF"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon
                                                    FontSize="17"
                                                    Foreground="{StaticResource AccentBrush}"
                                                    Glyph="&#xE768;" />
                                                <TextBlock
                                                    x:Name="AudioStatusText"
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource MutedTextBrush}"
                                                    MaxLines="2"
                                                    Text="No audio attached"
                                                    TextTrimming="CharacterEllipsis"
                                                    TextWrapping="Wrap" />
                                            </Grid>

                                            <TextBlock
                                                Foreground="{StaticResource InkBrush}"
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Text="Audio files" />

                                            <StackPanel
                                                x:Name="AudioListPanel"
                                                Spacing="8" />

                                            <Grid ColumnSpacing="8" Visibility="Collapsed">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Button
                                                    x:Name="PlayAudioButton"
                                                    HorizontalAlignment="Stretch"
                                                    Background="{StaticResource AccentBrush}"
                                                    Click="PlayAudio_Click"
                                                    Foreground="White"
                                                    IsEnabled="False">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <SymbolIcon Symbol="Play" />
                                                        <TextBlock x:Name="PlayAudioButtonText" Text="Play audio" />
                                                    </StackPanel>
                                                </Button>
                                                <Button
                                                    x:Name="StopAudioButton"
                                                    Grid.Column="1"
                                                    MinWidth="92"
                                                    Click="StopAudio_Click"
                                                    IsEnabled="False">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <SymbolIcon Symbol="Stop" />
                                                        <TextBlock x:Name="StopAudioButtonText" Text="Stop" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <MediaPlayerElement
                                                x:Name="AudioPlayerElement"
                                                Height="0"
                                                AreTransportControlsEnabled="False"
                                                AutoPlay="False"
                                                Visibility="Collapsed" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Spacing="8">
                                        <TextBlock
                                            x:Name="PhotoStatusText"
                                            Foreground="{StaticResource MutedTextBrush}"
                                            FontSize="12"
                                            Text="No photos yet" />
                                        <ScrollViewer
                                            MaxHeight="146"
                                            HorizontalScrollBarVisibility="Auto"
                                            VerticalScrollBarVisibility="Disabled">
                                            <StackPanel
                                                x:Name="PhotosPanel"
                                                Orientation="Horizontal"
                                                Spacing="8" />
                                        </ScrollViewer>
                                    </StackPanel>

                                    <Border
                                        Padding="10"
                                        Background="{StaticResource PanelAltBrush}"
                                        BorderBrush="#A8E3DF"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Visibility="Collapsed">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon
                                                    FontSize="17"
                                                    Foreground="{StaticResource AccentBrush}"
                                                    Glyph="&#xE8D2;" />
                                                <TextBlock
                                                    x:Name="TranscriptStatusText"
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource MutedTextBrush}"
                                                    Text="No transcript yet"
                                                    TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                            <TextBox
                                                x:Name="TranscriptBox"
                                                MinHeight="94"
                                                AcceptsReturn="True"
                                                IsReadOnly="True"
                                                PlaceholderText="Transcript will appear here after sync"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <TextBox
                                x:Name="TitleBox"
                                Header="Title"
                                PlaceholderText="Meeting, idea, call..." />
                            <RichEditBox
                                x:Name="BodyBox"
                                MinHeight="280"
                                Header="Text"
                                PlaceholderText="Start typing..."
                                TextWrapping="Wrap">
                                <RichEditBox.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            x:Name="BoldMenuItem"
                                            Click="BoldText_Click"
                                            Text="Bold" />
                                        <MenuFlyoutItem
                                            x:Name="ItalicMenuItem"
                                            Click="ItalicText_Click"
                                            Text="Italic" />
                                        <MenuFlyoutItem
                                            x:Name="HeadingMenuItem"
                                            Click="HeadingText_Click"
                                            Text="Heading" />
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem
                                            x:Name="BulletedListMenuItem"
                                            Click="BulletedList_Click"
                                            Text="Bulleted list" />
                                        <MenuFlyoutItem
                                            x:Name="NumberedListMenuItem"
                                            Click="NumberedList_Click"
                                            Text="Numbered list" />
                                        <MenuFlyoutItem
                                            x:Name="ChecklistMenuItem"
                                            Click="Checklist_Click"
                                            Text="Checklist" />
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem
                                            x:Name="QuoteMenuItem"
                                            Click="QuoteText_Click"
                                            Text="Quote" />
                                        <MenuFlyoutItem
                                            x:Name="CodeMenuItem"
                                            Click="CodeText_Click"
                                            Text="Code" />
                                        <MenuFlyoutItem
                                            x:Name="LinkMenuItem"
                                            Click="LinkText_Click"
                                            Text="Link" />
                                        <MenuFlyoutItem
                                            x:Name="TableMenuItem"
                                            Click="TableText_Click"
                                            Text="Table" />
                                    </MenuFlyout>
                                </RichEditBox.ContextFlyout>
                                <RichEditBox.KeyboardAccelerators>
                                    <KeyboardAccelerator
                                        Invoked="BoldText_Invoked"
                                        Key="B"
                                        Modifiers="Control" />
                                    <KeyboardAccelerator
                                        Invoked="ItalicText_Invoked"
                                        Key="I"
                                        Modifiers="Control" />
                                    <KeyboardAccelerator
                                        Invoked="LinkText_Invoked"
                                        Key="K"
                                        Modifiers="Control" />
                                </RichEditBox.KeyboardAccelerators>
                            </RichEditBox>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button
                            Click="NewNote_Click"
                            ToolTipService.ToolTip="Start a separate new note">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Add" />
                                <TextBlock x:Name="NewNoteButtonText" Text="New" />
                            </StackPanel>
                        </Button>
                        <Button
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Background="{StaticResource AccentBrush}"
                            Click="SaveNote_Click"
                            Foreground="White">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Save" />
                                <TextBlock x:Name="SaveNoteButtonText" Text="Save note" />
                            </StackPanel>
                        </Button>
                        <Button
                            Grid.Column="2"
                            MinWidth="104"
                            Background="{StaticResource DangerBrush}"
                            Click="DeleteNote_Click"
                            Foreground="White"
                            ToolTipService.ToolTip="Delete selected note">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Delete" />
                                <TextBlock x:Name="DeleteNoteButtonText" Text="Delete" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
