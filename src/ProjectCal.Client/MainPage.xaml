<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ProjectCal_Client.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="#EEF1EC"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#EEF1EC" />
        <SolidColorBrush x:Key="PanelBrush" Color="#F7F7F2" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="LineBrush" Color="#E5E2DA" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6F6A62" />
        <SolidColorBrush x:Key="InkBrush" Color="#211F1B" />
        <SolidColorBrush x:Key="InputBrush" Color="#141816" />
        <SolidColorBrush x:Key="InputHoverBrush" Color="#1B211E" />
        <SolidColorBrush x:Key="InputPressedBrush" Color="#101311" />
        <SolidColorBrush x:Key="InputTextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="InputPlaceholderBrush" Color="#AEB7B1" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#DCEFE6" />
        <SolidColorBrush x:Key="AccentBrush" Color="#317A5B" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B24A43" />

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InputTextBrush}" />
            <Setter Property="PlaceholderForeground" Value="{StaticResource InputPlaceholderBrush}" />
            <Setter Property="BorderBrush" Value="#2D3732" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="12,0,12,0" />
            <Setter Property="SelectionHighlightColor" Value="#317A5B" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InputTextBrush}" />
            <Setter Property="BorderBrush" Value="#2D3732" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="12,0,12,0" />
            <Setter Property="SelectionHighlightColor" Value="#317A5B" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InputTextBrush}" />
            <Setter Property="BorderBrush" Value="#2D3732" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="40" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InputTextBrush}" />
            <Setter Property="BorderBrush" Value="#2D3732" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="40" />
        </Style>

        <Style TargetType="TimePicker">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InputTextBrush}" />
            <Setter Property="BorderBrush" Value="#2D3732" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="40" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="14,8,14,8" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid
            x:Name="AuthScreen"
            Padding="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="480" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="1"
                Grid.Column="1"
                Padding="30"
                Background="{StaticResource PanelAltBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="10">
                        <Border
                            Width="44"
                            Height="44"
                            HorizontalAlignment="Left"
                            Background="{StaticResource AccentSoftBrush}"
                            CornerRadius="8">
                            <FontIcon
                                FontSize="22"
                                Foreground="{StaticResource AccentBrush}"
                                Glyph="&#xE787;" />
                        </Border>
                        <TextBlock
                            Foreground="{StaticResource InkBrush}"
                            FontSize="32"
                            FontWeight="SemiBold"
                            Text="ProjectCal" />
                        <TextBlock
                            Foreground="{StaticResource MutedTextBrush}"
                            FontSize="14"
                            LineHeight="20"
                            Text="Sign in to open your notes, calendar and voice transcripts."
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Spacing="12">
                        <StackPanel Spacing="6">
                            <TextBlock
                                Foreground="{StaticResource InkBrush}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="Email" />
                            <TextBox
                                x:Name="EmailBox"
                                PlaceholderText="you@example.com" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock
                                Foreground="{StaticResource InkBrush}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="Password" />
                            <PasswordBox
                                x:Name="PasswordBox"
                                PlaceholderText="Minimum 8 characters" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock
                                Foreground="{StaticResource InkBrush}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Text="Reset token" />
                            <TextBox
                                x:Name="TokenBox"
                                PlaceholderText="Only needed after Forgot" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Spacing="10">
                        <Button
                            HorizontalAlignment="Stretch"
                            Background="{StaticResource AccentBrush}"
                            Click="Login_Click"
                            Foreground="White">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Contact" />
                                <TextBlock Text="Login" />
                            </StackPanel>
                        </Button>
                        <Button
                            HorizontalAlignment="Stretch"
                            Background="{StaticResource AccentSoftBrush}"
                            Click="Register_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="AddFriend" />
                                <TextBlock Text="Register" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Grid Grid.Row="3" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button
                            HorizontalAlignment="Stretch"
                            Click="ForgotPassword_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Help" />
                                <TextBlock Text="Forgot" />
                            </StackPanel>
                        </Button>
                        <Button
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Click="ResetPassword_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Repair" />
                                <TextBlock Text="Reset" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border
                        Grid.Row="4"
                        Padding="12"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                FontSize="16"
                                Foreground="{StaticResource AccentBrush}"
                                Glyph="&#xE946;" />
                            <TextBlock
                                x:Name="AuthStatusBox"
                                Grid.Column="1"
                                Foreground="{StaticResource MutedTextBrush}"
                                LineHeight="18"
                                Text="Register once, then login. Use Forgot and Reset only if you need to change the password."
                                TextWrapping="Wrap" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid
            x:Name="AppShell"
            Padding="18"
            ColumnSpacing="14"
            Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <Border
                Padding="18"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            Foreground="{StaticResource InkBrush}"
                            FontSize="26"
                            FontWeight="SemiBold"
                            Text="ProjectCal" />
                        <TextBlock
                            x:Name="UserLabel"
                            Foreground="{StaticResource MutedTextBrush}"
                            FontSize="13"
                            Text="Calendar-first notes" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Spacing="10">
                        <Button
                            HorizontalAlignment="Stretch"
                            Background="{StaticResource AccentBrush}"
                            Click="Sync_Click"
                            Foreground="White">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Sync" />
                                <TextBlock Text="Sync" />
                            </StackPanel>
                        </Button>
                        <Button
                            HorizontalAlignment="Stretch"
                            Click="Settings_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Setting" />
                                <TextBlock Text="Settings" />
                            </StackPanel>
                        </Button>
                        <Button
                            HorizontalAlignment="Stretch"
                            Click="Logout_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Back" />
                                <TextBlock Text="Logout" />
                            </StackPanel>
                        </Button>
                        <Border
                            Padding="12"
                            Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="10">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Width="34"
                                        Height="34"
                                        Background="{StaticResource AccentSoftBrush}"
                                        CornerRadius="8">
                                        <FontIcon
                                            x:Name="StatusGlyph"
                                            FontSize="17"
                                            Foreground="{StaticResource AccentBrush}"
                                            Glyph="&#xE930;" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock
                                            Foreground="{StaticResource InkBrush}"
                                            FontWeight="SemiBold"
                                            Text="Activity" />
                                        <TextBlock
                                            x:Name="StatusBox"
                                            Foreground="{StaticResource MutedTextBrush}"
                                            LineHeight="18"
                                            MaxLines="3"
                                            Text="Ready"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>

                                <Grid ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border
                                        Padding="9"
                                        Background="{StaticResource PanelBrush}"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="3">
                                            <FontIcon
                                                FontSize="14"
                                                Foreground="{StaticResource AccentBrush}"
                                                Glyph="&#xE895;" />
                                            <TextBlock
                                                Foreground="{StaticResource InkBrush}"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Text="Sync" />
                                            <TextBlock
                                                x:Name="SyncStateText"
                                                Foreground="{StaticResource MutedTextBrush}"
                                                FontSize="11"
                                                Text="Idle" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Grid.Column="1"
                                        Padding="9"
                                        Background="{StaticResource PanelBrush}"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="3">
                                            <FontIcon
                                                FontSize="14"
                                                Foreground="{StaticResource AccentBrush}"
                                                Glyph="&#xE8B9;" />
                                            <TextBlock
                                                Foreground="{StaticResource InkBrush}"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Text="Media" />
                                            <TextBlock
                                                x:Name="MediaStateText"
                                                Foreground="{StaticResource MutedTextBrush}"
                                                FontSize="11"
                                                Text="None" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Padding="9"
                                        Background="{StaticResource PanelBrush}"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon
                                                FontSize="14"
                                                Foreground="{StaticResource AccentBrush}"
                                                Glyph="&#xE8D2;" />
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock
                                                    Foreground="{StaticResource InkBrush}"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Text="Transcript" />
                                                <TextBlock
                                                    x:Name="TranscriptStateText"
                                                    Foreground="{StaticResource MutedTextBrush}"
                                                    FontSize="11"
                                                    Text="No audio" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Padding="16"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="2">
                            <TextBlock
                                Foreground="{StaticResource InkBrush}"
                                FontSize="22"
                                FontWeight="SemiBold"
                                Text="Day timeline" />
                            <TextBlock
                                Foreground="{StaticResource MutedTextBrush}"
                                FontSize="13"
                                Text="Focus on one day, one hour at a time" />
                        </StackPanel>

                        <DatePicker
                            x:Name="DayPicker"
                            Grid.Column="1"
                            DateChanged="DayPicker_DateChanged"
                            Header="Day" />
                        <TextBox
                            x:Name="SearchBox"
                            Grid.Column="2"
                            Header="Search"
                            PlaceholderText="Search notes or transcript"
                            TextChanged="SearchBox_TextChanged" />
                    </Grid>
                </Border>

                <Border
                    Grid.Row="1"
                    Padding="12"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <ScrollViewer>
                        <StackPanel x:Name="HoursPanel" Spacing="6" />
                    </ScrollViewer>
                </Border>
            </Grid>

            <Border
                Grid.Column="2"
                Padding="18"
                Background="{StaticResource PanelAltBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock
                            Foreground="{StaticResource InkBrush}"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Text="Note" />
                        <TextBlock
                            Foreground="{StaticResource MutedTextBrush}"
                            FontSize="13"
                            Text="Write, attach photos, or record audio" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1">
                        <StackPanel Spacing="14">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TimePicker
                                    x:Name="StartTimePicker"
                                    ClockIdentifier="24HourClock"
                                    Header="Start" />
                                <TimePicker
                                    x:Name="EndTimePicker"
                                    Grid.Column="1"
                                    ClockIdentifier="24HourClock"
                                    Header="End" />
                            </Grid>

                            <Border
                                Padding="14"
                                Background="{StaticResource AccentSoftBrush}"
                                BorderBrush="#B8D9CA"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock
                                                Foreground="{StaticResource InkBrush}"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Text="Voice &amp; media" />
                                            <TextBlock
                                                Foreground="{StaticResource MutedTextBrush}"
                                                FontSize="12"
                                                Text="Record audio for transcription or attach photos." />
                                        </StackPanel>
                                        <ComboBox
                                            x:Name="LanguageBox"
                                            Grid.Column="1"
                                            Width="88"
                                            SelectedIndex="0">
                                            <ComboBoxItem Content="auto" />
                                            <ComboBoxItem Content="ru" />
                                            <ComboBoxItem Content="uk" />
                                            <ComboBoxItem Content="en" />
                                        </ComboBox>
                                    </Grid>

                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button
                                            x:Name="RecordButton"
                                            HorizontalAlignment="Stretch"
                                            Background="{StaticResource AccentBrush}"
                                            Click="RecordAudio_Click"
                                            Foreground="White">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <SymbolIcon Symbol="Microphone" />
                                                <TextBlock Text="Record audio" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            Grid.Column="1"
                                            HorizontalAlignment="Stretch"
                                            Click="AttachPhoto_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <SymbolIcon Symbol="Pictures" />
                                                <TextBlock Text="Add photo" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <Border
                                        x:Name="MediaActionBorder"
                                        Padding="10"
                                        Background="{StaticResource PanelAltBrush}"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Visibility="Collapsed">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ProgressRing
                                                x:Name="MediaActionRing"
                                                Width="20"
                                                Height="20"
                                                IsActive="False" />
                                            <TextBlock
                                                x:Name="MediaActionText"
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource MutedTextBrush}"
                                                Text="Media is ready"
                                                TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>

                                    <Border
                                        Padding="10"
                                        Background="{StaticResource PanelAltBrush}"
                                        BorderBrush="#B8D9CA"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon
                                                    FontSize="17"
                                                    Foreground="{StaticResource AccentBrush}"
                                                    Glyph="&#xE768;" />
                                                <TextBlock
                                                    x:Name="AudioStatusText"
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource MutedTextBrush}"
                                                    Text="No audio attached"
                                                    TextTrimming="CharacterEllipsis" />
                                            </Grid>

                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Button
                                                    x:Name="PlayAudioButton"
                                                    HorizontalAlignment="Stretch"
                                                    Background="{StaticResource AccentBrush}"
                                                    Click="PlayAudio_Click"
                                                    Foreground="White"
                                                    IsEnabled="False">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <SymbolIcon Symbol="Play" />
                                                        <TextBlock Text="Play audio" />
                                                    </StackPanel>
                                                </Button>
                                                <Button
                                                    x:Name="StopAudioButton"
                                                    Grid.Column="1"
                                                    MinWidth="92"
                                                    Click="StopAudio_Click"
                                                    IsEnabled="False">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <SymbolIcon Symbol="Stop" />
                                                        <TextBlock Text="Stop" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <MediaPlayerElement
                                                x:Name="AudioPlayerElement"
                                                Height="74"
                                                AreTransportControlsEnabled="True"
                                                AutoPlay="False"
                                                Visibility="Collapsed" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Spacing="8">
                                        <TextBlock
                                            x:Name="PhotoStatusText"
                                            Foreground="{StaticResource MutedTextBrush}"
                                            FontSize="12"
                                            Text="No photos yet" />
                                        <ScrollViewer
                                            MaxHeight="146"
                                            HorizontalScrollBarVisibility="Auto"
                                            VerticalScrollBarVisibility="Disabled">
                                            <StackPanel
                                                x:Name="PhotosPanel"
                                                Orientation="Horizontal"
                                                Spacing="8" />
                                        </ScrollViewer>
                                    </StackPanel>

                                    <Border
                                        Padding="10"
                                        Background="{StaticResource PanelAltBrush}"
                                        BorderBrush="#B8D9CA"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon
                                                    FontSize="17"
                                                    Foreground="{StaticResource AccentBrush}"
                                                    Glyph="&#xE8D2;" />
                                                <TextBlock
                                                    x:Name="TranscriptStatusText"
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Foreground="{StaticResource MutedTextBrush}"
                                                    Text="No transcript yet"
                                                    TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                            <TextBox
                                                x:Name="TranscriptBox"
                                                MinHeight="94"
                                                AcceptsReturn="True"
                                                IsReadOnly="True"
                                                PlaceholderText="Transcript will appear here after sync"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <TextBox
                                x:Name="TitleBox"
                                Header="Title"
                                PlaceholderText="Meeting, idea, call..." />
                            <TextBox
                                x:Name="BodyBox"
                                MinHeight="280"
                                AcceptsReturn="True"
                                Header="Text"
                                PlaceholderText="Start typing..."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button
                            Click="NewNote_Click"
                            ToolTipService.ToolTip="Start a separate new note">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Add" />
                                <TextBlock Text="New" />
                            </StackPanel>
                        </Button>
                        <Button
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Background="{StaticResource AccentBrush}"
                            Click="SaveNote_Click"
                            Foreground="White">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Save" />
                                <TextBlock Text="Save note" />
                            </StackPanel>
                        </Button>
                        <Button
                            Grid.Column="2"
                            MinWidth="104"
                            Background="{StaticResource DangerBrush}"
                            Click="DeleteNote_Click"
                            Foreground="White"
                            ToolTipService.ToolTip="Delete selected note">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Delete" />
